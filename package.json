{
  "name": "@tummycrypt/tinyland-color-utils",
  "version": "0.1.0",
  "description": "Pure JavaScript color utilities with WCAG contrast validation, color space conversions, and caching",
  "type": "module",
  "license": "(Zlib AND LicenseRef-Tinyland-Proprietary)",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/utils/color/types.d.ts",
      "import": "./dist/utils/color/types.js"
    },
    "./cache": {
      "types": "./dist/utils/color/cache.d.ts",
      "import": "./dist/utils/color/cache.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "color",
    "wcag",
    "contrast",
    "accessibility",
    "a11y",
    "oklch",
    "oklab"
  ],
  "author": "Tinyland Inc.",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/tinyland/projects/tinyland.dev.git",
    "directory": "packages/tinyland-color-utils"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^3.0.0",
    "fast-check": "^4.3.0",
    "@fast-check/vitest": "^0.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  }
}
