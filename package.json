{
  "name": "@tummycrypt/tinyland-color-utils",
  "version": "0.2.2",
  "description": "Pure JavaScript color utilities with WCAG contrast validation, color space conversions, and caching",
  "type": "module",
  "license": "(Zlib AND LicenseRef-Tinyland-Proprietary)",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/utils/color/types.d.ts",
      "import": "./dist/utils/color/types.js"
    },
    "./cache": {
      "types": "./dist/utils/color/cache.d.ts",
      "import": "./dist/utils/color/cache.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build && pnpm check:package",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check:package": "publint"
  },
  "keywords": [
    "color",
    "wcag",
    "contrast",
    "accessibility",
    "a11y",
    "oklch",
    "oklab"
  ],
  "author": "Tinyland Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinyland-inc/tinyland-color-utils.git"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.2.4",
    "@types/node": "^24.6.0",
    "fast-check": "^4.3.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.0",
    "publint": "^0.3.18"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "packageManager": "pnpm@10.13.1",
  "homepage": "https://github.com/tinyland-inc/tinyland-color-utils",
  "bugs": {
    "url": "https://github.com/tinyland-inc/tinyland-color-utils/issues"
  }
}